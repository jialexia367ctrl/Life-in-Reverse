# ============================================================
# 反向人生交易所 - Environment Variables
# ============================================================

# 本地开发模式：使用 Express/SQLite 演示后端
VITE_BACKEND_MODE=local
VITE_API_URL=http://localhost:3001
PORT=3001
CORS_ORIGIN=http://localhost:5173

# 生产模式：部署到 Vercel 时设置下面两个变量，并删除/不设置 VITE_BACKEND_MODE=local
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Edge Function secrets (不要放到 Vercel 前端环境变量里)
# 用 supabase secrets set 写入：
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_SUCCESS_URL=https://your-domain.com/payment/success
# STRIPE_CANCEL_URL=https://your-domain.com/payment/cancel
